{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/:match*", "destination": "https://medassist-ai-gpxn.onrender.com/:match*" },
    { "source": "/nim-api/:match*", "destination": "https://integrate.api.nvidia.com/v1/:match*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
