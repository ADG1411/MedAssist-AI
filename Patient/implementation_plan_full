## PHASE 6 — UNIFIED MEDICAL IDENTITY & QR CARE BOND (Week 13-14)
### *Digital Health Passport + Doctor Bonds + Family Access + Emergency QR*

> [!IMPORTANT]
> This is the **capstone phase**. It ties together every module — profile, records, doctors, SOS, vitals — into a single portable medical identity that feels like India's ABHA but smarter.

### 6.1 — Database Schema

```sql
-- Patient Health Identity
CREATE TABLE patient_health_identity (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID REFERENCES auth.users NOT NULL UNIQUE,
    health_id TEXT NOT NULL UNIQUE,          -- Format: MED-2026-XXXXXXXX
    qr_payload_hash TEXT,                    -- Hash of current QR data for integrity
    primary_doctor_id UUID REFERENCES doctors,
    insurance_provider TEXT,
    insurance_id TEXT,
    emergency_access_enabled BOOLEAN DEFAULT TRUE,
    public_profile_enabled BOOLEAN DEFAULT FALSE,
    created_at TIMESTAMPTZ DEFAULT now(),
    updated_at TIMESTAMPTZ DEFAULT now()
);

-- Doctor-Patient Care Bonds
CREATE TABLE doctor_patient_bonds (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID REFERENCES auth.users NOT NULL,
    doctor_id UUID REFERENCES doctors NOT NULL,
    trust_score INT DEFAULT 50,             -- 0-100, increases with consultations
    consultation_count INT DEFAULT 0,
    is_favorite BOOLEAN DEFAULT FALSE,
    is_primary BOOLEAN DEFAULT FALSE,
    first_consultation DATE,
    last_consultation DATE,
    shared_permissions JSONB DEFAULT '{"reports": false, "prescriptions": false, "vitals": false, "ai_results": false}',
    created_at TIMESTAMPTZ DEFAULT now(),
    UNIQUE(user_id, doctor_id)
);

-- Temporary QR Share Tokens
CREATE TABLE qr_share_tokens (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID REFERENCES auth.users NOT NULL,
    token TEXT NOT NULL UNIQUE,
    scope TEXT NOT NULL,                    -- 'full_passport', 'emergency_only', 'records_only', 'doctor_handoff'
    shared_record_ids UUID[] DEFAULT '{}',  -- Specific records to share
    expires_at TIMESTAMPTZ NOT NULL,
    accessed_by UUID[] DEFAULT '{}',        -- Who scanned it
    access_count INT DEFAULT 0,
    is_revoked BOOLEAN DEFAULT FALSE,
    created_at TIMESTAMPTZ DEFAULT now()
);

-- Family / Guardian Access
CREATE TABLE family_access (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    patient_id UUID REFERENCES auth.users NOT NULL,
    guardian_id UUID REFERENCES auth.users NOT NULL,
    relationship TEXT NOT NULL,             -- 'parent', 'child', 'spouse', 'sibling', 'guardian'
    guardian_name TEXT NOT NULL,
    permissions JSONB DEFAULT '{"reports": false, "prescriptions": false, "sos": true, "appointments": false, "vitals": false}',
    status TEXT DEFAULT 'pending',          -- 'pending', 'active', 'revoked'
    linked_via TEXT DEFAULT 'qr',           -- 'qr', 'invite_code', 'manual'
    created_at TIMESTAMPTZ DEFAULT now(),
    UNIQUE(patient_id, guardian_id)
);
```

